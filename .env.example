# Supabase Configuration
# Get these from https://app.supabase.com > Project Settings > API > Keys & Tokens
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Supabase Service Role Key (for backend scripts only)
# Keep this secret and NEVER commit to git
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Brevo API Key (for email sending)
# Get from https://app.brevo.com > Settings > SMTP & API
BREVO_API_KEY=your_brevo_api_key_here

# Note: Copy this file to .env.local and fill in the actual values
# .env.local is in .gitignore and should never be committed
